<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Connexion</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: Arial, Helvetica, sans-serif;
        background: #f6f8fb;
        color: #172033;
      }
      main {
        width: min(92vw, 520px);
        padding: 32px;
        background: #ffffff;
        border: 1px solid #d8dee8;
        border-radius: 8px;
        box-shadow: 0 12px 28px rgba(23, 32, 51, 0.10);
      }
      h1 {
        margin: 0 0 12px;
        font-size: 28px;
        font-weight: 700;
      }
      p {
        margin: 0 0 24px;
        color: #4a5568;
        line-height: 1.5;
      }
      nav {
        display: grid;
        gap: 12px;
      }
      .button {
        display: block;
        padding: 12px 16px;
        border-radius: 6px;
        background: #155eef;
        color: #ffffff;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
      }
      .button:focus,
      .button:hover {
        background: #0f46b5;
      }
    </style>
  </head>
  <body>
    <main class="logout-login-page">
      <h1>Connexion</h1>
      <p>La deconnexion SAML est terminee.</p>
      <nav aria-label="Applications disponibles">
{{FRONT_REDIRECT_BUTTONS}}
      </nav>
    </main>
  </body>
</html>
